{
  "manifest_version": 3,
  "name": "¿Dev, Stage o Prod?",
  "version": "1.0.0",
  "description": "Detecta en qué ambiente estás",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}